# База данных PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_NAME=postgres

# API ключ для hh.ru
ACCESS_TOKEN_HH=your-hh-api-token

# Email (SMTP)
FROM_EMAIL=your@email.ru
HOST_NAME=smtp.mail.ru
PORT=465
APPLICATION_KEY=your-smtp-app-password
FEEDBACK_EMAIL=feedback@your-domain.ru

# JWT
BASE_ALGORITM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Внутренний API ключ (должен совпадать с API_KEY во фронтенде)
API_WFE_KEY=wfe_your-key-here

# Admin панель (SQLAdmin)
SECRET_KEY=your-secret-key
ADMIN_LOGIN=admin
ADMIN_PASSWORD=your-admin-password
